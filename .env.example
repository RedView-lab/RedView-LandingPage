NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Supabase service role (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (test mode keys — switch to live keys for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price ID (create product in dashboard: https://dashboard.stripe.com/test/products)
STRIPE_PRICE_ID=price_xxx
