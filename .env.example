NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Destination app after successful auth exchange
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Supabase service role (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe (test mode keys — switch to live keys for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price ID (create product in dashboard: https://dashboard.stripe.com/test/products)
STRIPE_PRICE_ID=price_xxx

# Feedback form delivery with Resend API
# Test mode: keep onboarding@resend.dev until your sending domain is verified.
# Limitation: the resend.dev testing sender only works to your own Resend account email.
RESEND_API_KEY=re_your_resend_api_key
FEEDBACK_EMAIL_FROM=RedView Feedback <onboarding@resend.dev>
# Optional for tests before domain verification; defaults to redview.app@proton.me in code.
FEEDBACK_EMAIL_TO=your-resend-account-email@example.com
